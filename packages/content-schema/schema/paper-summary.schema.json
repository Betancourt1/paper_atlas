{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-atlas.local/schemas/paper-summary.schema.json",
  "title": "PaperSummary",
  "description": "The minimal public paper contract used by Paper Atlas M0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "slug",
    "title",
    "summary",
    "authors",
    "published_year",
    "source",
    "version",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^paper_[a-z0-9_]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/author"
      }
    },
    "published_year": {
      "type": "integer",
      "minimum": 1600,
      "maximum": 2100
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "version": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "INDEXED",
        "EXPLAINER_PENDING",
        "DRAFT",
        "REVIEWED",
        "PUBLISHED"
      ]
    }
  },
  "$defs": {
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^author_[a-z0-9_]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "identifier", "url"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ARXIV", "DOI", "URL"]
        },
        "identifier": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
